pipeline {
    agent any
    
    environment {
        DOCKER_IMAGE = "piyatida26/medicine-stock-api/medicine-stock"
        DOCKER_REGISTRY = "docker.io"
        DOCKER_CREDENTIALS = credentials('dockerhub-credentials')
        KUBE_NAMESPACE = "medicine-stock"
        DB_PATH = "/app/medicine.db"
    }
    
    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Docker image tag')
        booleanParam(name: 'PUSH_TO_REGISTRY', defaultValue: true, description: 'Push image to Docker Registry')
        booleanParam(name: 'DEPLOY_K8S', defaultValue: true, description: 'Deploy to Kubernetes')
    }
    
    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 1, unit: 'HOURS')
    }
    
    stages {
        stage('1. Checkout & Setup') {
            steps {
                script {
                    echo "========== Checkout Git Repository =========="
                    checkout scm
                    sh 'git log -1 --oneline'
                    // ใช้ env.GIT_BRANCH เพื่อดึงชื่อ Branch ในโปรเจกต์ธรรมดาอย่างปลอดภัย
                    echo "Current branch: ${env.GIT_BRANCH ?: 'main'}"
                }
            }
        }
        
        stage('2. Unit Test') {
            steps {
                script {
                    echo "========== Running Unit Tests =========="
                    try {
                        sh '''
                            cd medicine-stock-devops/app
                            python -m pytest test_app.py -v --tb=short --junit-xml=test-results.xml
                        '''
                    } catch (Exception e) {
                        echo "Tests failed: ${e.message}"
                        currentBuild.result = 'UNSTABLE'
                    }
                }
            }
            post {
                always {
                    // ครอบด้วย catchError เผื่อกรณี Jenkins ของคุณยังไม่มีปลั๊กอิน JUnit ระบบจะได้ไม่หยุดทำงาน
                    catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                        junit 'medicine-stock-devops/app/test-results.xml'
                    }
                }
            }
        }
        
        stage('3. Build Docker Image') {
            steps {
                script {
                    echo "========== Building Docker Image =========="
                    // ใช้ฟันหนูคู่ (Double Quotes) เพื่อให้ Jenkins แทนค่าตัวแปร params.IMAGE_TAG ลงไปในคำสั่ง sh ได้ถูกต้อง
                    sh """
                        cd medicine-stock-devops
                        docker build -t ${DOCKER_IMAGE}:${params.IMAGE_TAG} \
                                    -t ${DOCKER_IMAGE}:latest \
                                    -f Dockerfile .
                    """
                }
            }
        }
        
        stage('4. Security Scan') {
            steps {
                script {
                    echo "========== Container Security Scan =========="
                    sh """
                        if command -v trivy &> /dev/null; then
                            trivy image --exit-code 0 --severity CRITICAL,HIGH ${DOCKER_IMAGE}:${params.IMAGE_TAG}
                        else
                            echo "Trivy not installed, skipping scan"
                        fi
                    """
                }
            }
        }
        
        stage('5. Push to Docker Registry') {
            when {
                expression { params.PUSH_TO_REGISTRY == true }
            }
            steps {
                script {
                    echo "========== Pushing Image to Docker Hub =========="
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', 
                                                     usernameVariable: 'DOCKER_USER', 
                                                     passwordVariable: 'DOCKER_PASS')]) {
                        sh """
                            echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                            docker push ${DOCKER_IMAGE}:${params.IMAGE_TAG}
                            docker push ${DOCKER_IMAGE}:latest
                            docker logout
                        """
                    }
                }
            }
        }
        
        stage('6. Deploy to Kubernetes') {
            when {
                expression { params.DEPLOY_K8S == true }
            }
            steps {
                script {
                    echo "========== Phase 3: Infrastructure & Configuration =========="
                    
                    echo ">>> Step 1: Terraform Infrastructure Provisioning..."
                    sh '''
                        cd terraform
                        terraform init
                        terraform validate
                        terraform plan -out=tfplan
                        terraform apply -auto-approve tfplan
                        cd ..
                    '''
                    
                    echo ">>> Step 2: Ansible Infrastructure Configuration..."
                    sh '''
                        cd ansible
                        ansible-playbook -i inventory playbook.yml -v
                        cd ..
                    '''
                    
                    echo ">>> Step 3: Kubernetes Application Deployment..."
                    sh """
                        kubectl set image deployment/medicine-stock \
                                medicine-stock=${DOCKER_IMAGE}:${params.IMAGE_TAG} \
                                -n ${KUBE_NAMESPACE} || \
                        kubectl apply -f k8s/deployment.yaml -n ${KUBE_NAMESPACE}
                        
                        kubectl apply -f k8s/service.yaml -n ${KUBE_NAMESPACE}
                    """
                }
            }
        }
    }
    
    post {
        always {
            script {
                echo "========== Pipeline Cleanup =========="
                sh 'docker image prune -f --filter "until=24h" || true'
            }
        }
    }
}