pipeline {
    agent any
    
    environment {
        DOCKER_IMAGE = "natthaphong4101/medicine-stock" 
    DOCKER_REGISTRY = "docker.io"
        DOCKER_CREDENTIALS = credentials('dockerhub-credentials')
        KUBE_NAMESPACE = "medicine-stock"
        DB_PATH = "/app/medicine.db"
    }
    
    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Docker image tag')
        booleanParam(name: 'PUSH_TO_REGISTRY', defaultValue: true, description: 'Push image to Docker Registry')
        booleanParam(name: 'DEPLOY_K8S', defaultValue: true, description: 'Deploy to Kubernetes')
    }
    
    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 1, unit: 'HOURS')
    }
    
    stages {
        stage('1. Checkout & Setup') {
            steps {
                script {
                    echo "========== Checkout Git Repository =========="
                    checkout scm
                    sh 'git log -1 --oneline'
                    // ใช้ env.GIT_BRANCH เพื่อดึงชื่อ Branch ในโปรเจกต์ธรรมดาอย่างปลอดภัย
                    echo "Current branch: ${env.GIT_BRANCH ?: 'main'}"
                }
            }
        }
        
        stage('2. Unit Test') {
            steps {
                script {
                    echo "========== Preparing Environment & Running Tests =========="
                    try {
                        sh '''
                            apt-get update && apt-get install -y python3-pytest python3-pip || true
                            cd medicine-stock-devops/app
                            pip3 install -r requirements.txt --break-system-packages || pip3 install flask pytest requests || true
                            pytest test_app.py -v --tb=short --junit-xml=test-results.xml
                        '''
                    } catch (Exception e) {
                        echo "Tests failed: ${e.message}"
                        currentBuild.result = 'UNSTABLE'
                    }
                }
            }
        }
        
        stage('3. Build Docker Image') {
            steps {
                script {
                    echo "========== Installing Docker CLI & Building Image =========="
                    // สั่งลง Docker CLI สดๆ ก่อนสั่ง Build
                    sh """
                        apt-get update && apt-get install -y docker.io || true
                        cd medicine-stock-devops
                        docker build -t ${DOCKER_IMAGE}:${params.IMAGE_TAG} \
                                     -t ${DOCKER_IMAGE}:latest \
                                     -f Dockerfile .
                        docker image ls | grep medicine-stock || true
                    """
                }
            }
        }
        
        stage('4. Security Scan') {
            steps {
                script {
                    echo "========== Container Security Scan =========="
                    // ใช้ตัวแปรสคริปต์ตรวจสอบก่อนส่งเข้าคำสั่ง sh
                    sh """
                        if [ -x "\$(command -v trivy)" ]; then
                            trivy image --exit-code 0 --severity CRITICAL,HIGH ${DOCKER_IMAGE}:${params.IMAGE_TAG}
                        else
                            echo "Trivy is not installed in Jenkins environment, skipping scan."
                        fi
                    """
                }
            }
        }
        
        stage('5. Push to Docker Registry') {
            when {
                expression { params.PUSH_TO_REGISTRY == true }
            }
            steps {
                script {
                    echo "========== Pushing Image to Docker Hub =========="
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', 
                                                     usernameVariable: 'DOCKER_USER', 
                                                     passwordVariable: 'DOCKER_PASS')]) {
                        sh """
                            echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                            docker push ${DOCKER_IMAGE}:${params.IMAGE_TAG}
                            docker push ${DOCKER_IMAGE}:latest
                            docker logout
                        """
                    }
                }
            }
        }
        
        stage('6. Deploy to Kubernetes') {
            when {
                expression { params.DEPLOY_K8S == true }
            }
            steps {
                script {
                    echo "========== Phase 3: Infrastructure & Configuration =========="
                    
                    // ติดตั้งเครื่องมือพื้นฐานในตู้ Jenkins ก่อนเริ่มรันงาน
                    echo ">>> Installing Infrastructure Tools (Terraform, Ansible, Kubectl)..."
                    sh '''
                        apt-get update && apt-get install -y gnupg software-properties-common curl jq || true
                        
                        # 1. ติดตั้ง Terraform
                        if ! command -v terraform &> /dev/null; then
                            curl -fsSL https://apt.releases.hashicorp.com/gpg | gpg --dearmor -o /usr/share/keyrings/hashicorp-archive-keyring.gpg || true
                            echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com/trixie main" | tee /etc/apt/sources.list.d/hashicorp.list || true
                            apt-get update && apt-get install -y terraform || true
                        fi
                        
                        # 2. ติดตั้ง Ansible
                        if ! command -v ansible-playbook &> /dev/null; then
                            apt-get install -y ansible || true
                        fi
                        
                        # 3. ติดตั้ง Kubectl
                        if ! command -v kubectl &> /dev/null; then
                            curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/arm64/kubectl" || true
                            install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl || true
                        fi
                    '''
                    
                    echo ">>> Step 1: Terraform Infrastructure Provisioning..."
                    sh '''
                        cd medicine-stock-devops/terraform
                        terraform init
                        terraform validate
                        terraform plan -out=tfplan
                        terraform apply -auto-approve tfplan
                        cd ../..
                    '''
                    
                    echo ">>> Step 2: Ansible Infrastructure Configuration..."
                    sh '''
                        cd medicine-stock-devops/ansible
                        ansible-playbook -i inventory playbook.yml -v
                        cd ../..
                    '''
                    
                    echo ">>> Step 3: Kubernetes Application Deployment..."
                    sh """
                        kubectl set image deployment/medicine-stock \
                                medicine-stock=${DOCKER_IMAGE}:${params.IMAGE_TAG} \
                                -n ${KUBE_NAMESPACE} || \
                        kubectl apply -f medicine-stock-devops/k8s/deployment.yaml -n ${KUBE_NAMESPACE}
                        
                        kubectl apply -f medicine-stock-devops/k8s/service.yaml -n ${KUBE_NAMESPACE}
                    """
                }
            }
        }
    }
    
    post {
        always {
            script {
                echo "========== Pipeline Cleanup =========="
                sh 'docker image prune -f --filter "until=24h" || true'
            }
        }
    }
}