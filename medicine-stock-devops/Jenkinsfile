pipeline {
    agent any
    
    environment {
        DOCKER_IMAGE = "your-dockerhub-username/medicine-stock"
        DOCKER_TAG = "${BUILD_NUMBER}"
        DOCKER_REGISTRY = "docker.io"
        KUBE_NAMESPACE = "default"
        DB_PATH = "/app/medicine.db"
        PROJECT_DIR = "medicine-stock-devops"
    }
    
    parameters {
        string(name: 'IMAGE_TAG', defaultValue: '${BUILD_NUMBER}', description: 'Docker image tag')
        booleanParam(name: 'PUSH_TO_REGISTRY', defaultValue: false, description: 'Push image to Docker Registry')
        booleanParam(name: 'DEPLOY_K8S', defaultValue: false, description: 'Deploy to Kubernetes')
    }
    
    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 1, unit: 'HOURS')
    }
    
    stages {
        stage('1. Checkout & Setup') {
            steps {
                script {
                    echo "========== Checkout Git Repository =========="
                    checkout scm
                    sh 'git log -1 --oneline'
                    echo "Current branch: ${env.BRANCH_NAME ?: env.GIT_BRANCH ?: 'main'}"
                }
            }
        }
        
        stage('2. Unit Test') {
            steps {
                script {
                    echo "========== Running Unit Tests =========="
                    try {
                        sh '''
                            cd ${PROJECT_DIR}/app
                            python -m pytest test_app.py -v --tb=short --junit-xml=test-results.xml
                        '''
                    } catch (Exception e) {
                        echo "Tests failed: ${e.message}"
                        currentBuild.result = 'UNSTABLE'
                    }
                }
            }
            post {
                always {
                    junit testResults: "${PROJECT_DIR}/app/test-results.xml", allowEmptyResults: true
                }
            }
        }
        
        stage('3. Build Docker Image') {
            steps {
                script {
                    echo "========== Building Docker Image =========="
                    if (sh(script: 'command -v docker >/dev/null 2>&1', returnStatus: true) != 0) {
                        echo "Docker CLI not available on Jenkins agent, skipping Docker image build"
                    } else {
                        sh '''
                            docker build -t ${DOCKER_IMAGE}:${IMAGE_TAG} \
                                         -t ${DOCKER_IMAGE}:latest \
                                         -f ${PROJECT_DIR}/Dockerfile ${PROJECT_DIR}
                            docker image ls | grep medicine-stock
                        '''
                    }
                }
            }
        }
        
        stage('4. Security Scan') {
            steps {
                script {
                    echo "========== Container Security Scan =========="
                    try {
                        sh '''
                            # Optional: Run Trivy scan if installed
                            if command -v trivy &> /dev/null; then
                                trivy image --exit-code 0 --severity CRITICAL,HIGH \
                                           ${DOCKER_IMAGE}:${IMAGE_TAG}
                            else
                                echo "Trivy not installed, skipping scan"
                            fi
                        '''
                    } catch (Exception e) {
                        echo "Scan warning: ${e.message}"
                    }
                }
            }
        }
        
        stage('5. Push to Docker Registry') {
            when {
                expression { params.PUSH_TO_REGISTRY == true }
            }
            steps {
                script {
                    echo "========== Pushing Image to Docker Hub =========="
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', 
                                                     usernameVariable: 'DOCKER_USER', 
                                                     passwordVariable: 'DOCKER_PASS')]) {
                        sh '''
                            echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                            docker push ${DOCKER_IMAGE}:${IMAGE_TAG}
                            docker push ${DOCKER_IMAGE}:latest
                            docker logout
                            echo "Image pushed successfully"
                        '''
                    }
                }
            }
        }
        
        stage('6. Deploy to Kubernetes') {
            when {
                expression { params.DEPLOY_K8S == true }
            }
            steps {
                script {
                    echo "========== Phase 3: Infrastructure & Configuration =========="
                    
                    echo ">>> Step 1: Terraform Infrastructure Provisioning..."
                    sh '''
                        cd ${PROJECT_DIR}/terraform
                        terraform init
                        terraform validate
                        terraform plan -out=tfplan
                        terraform apply -auto-approve tfplan
                        terraform output -json | jq .
                        cd ..
                    '''
                    
                    echo ">>> Step 2: Ansible Infrastructure Configuration..."
                    sh '''
                        cd ${PROJECT_DIR}/ansible
                        ansible --version
                        ansible-playbook -i inventory playbook.yml -v
                        cd ..
                    '''
                    
                    echo ">>> Step 3: Kubernetes Application Deployment..."
                    sh '''
                        kubectl set image deployment/medicine-stock \
                                medicine-stock=${DOCKER_IMAGE}:${IMAGE_TAG} \
                                -n ${KUBE_NAMESPACE} || \
                        kubectl apply -f ${PROJECT_DIR}/k8s/deployment.yaml -n ${KUBE_NAMESPACE}
                        
                        kubectl apply -f ${PROJECT_DIR}/k8s/service.yaml -n ${KUBE_NAMESPACE}
                        
                        kubectl rollout status deployment/medicine-stock \
                                -n ${KUBE_NAMESPACE} --timeout=5m
                        
                        kubectl get pods -n ${KUBE_NAMESPACE} -l app=medicine-stock
                    '''
                }
            }
        }
    }
    
    post {
        always {
            script {
                echo "========== Pipeline Cleanup =========="
                // Clean up docker resources if needed
                sh 'docker image prune -f --filter "until=24h" || true'
            }
        }
        success {
            script {
                echo "========== Build Successful =========="
                sh '''
                    echo "Build completed successfully at $(date)" > build-status.txt
                    echo "Image: ${DOCKER_IMAGE}:${IMAGE_TAG}" >> build-status.txt
                '''
                // Optional: Send notification
                // emailext (subject: "Build Success: ${JOB_NAME}", ...)
            }
        }
        failure {
            script {
                echo "========== Build Failed =========="
                // Optional: Send notification
                // emailext (subject: "Build Failed: ${JOB_NAME}", ...)
            }
        }
        unstable {
            script {
                echo "========== Build Unstable (Tests Failed) =========="
            }
        }
    }
}
