pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "piyatida26/medicine-stock-api"
        DOCKER_REGISTRY = "docker.io"
        KUBE_NAMESPACE = "medicine-stock"
        PROJECT_DIR = "medicine-stock-devops"
        APP_DIR = "medicine-stock-devops/app"
    }

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Docker image tag, for example latest or build number')
        booleanParam(name: 'PUSH_TO_REGISTRY', defaultValue: false, description: 'Push image to Docker Hub')
        booleanParam(name: 'DEPLOY_K8S', defaultValue: false, description: 'Deploy to Kubernetes')
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 1, unit: 'HOURS')
    }

    stages {
        stage('1. Checkout & Setup') {
            steps {
                script {
                    echo "========== Checkout Git Repository =========="
                    checkout scm
                    sh 'git log -1 --oneline'
                    echo "Current branch: yeenny"

                    env.EFFECTIVE_IMAGE_TAG = params.IMAGE_TAG?.trim()
                    if (!env.EFFECTIVE_IMAGE_TAG) {
                        env.EFFECTIVE_IMAGE_TAG = env.BUILD_NUMBER
                    }

                    echo "Docker image: ${env.DOCKER_IMAGE}:${env.EFFECTIVE_IMAGE_TAG}"
                }
            }
        }

        stage('2. Unit Test') {
            steps {
                script {
                    echo "========== Running Unit Tests =========="
                    sh """
                        cd ${APP_DIR}

                        if command -v python3 >/dev/null 2>&1; then
                            PYTHON_CMD=python3
                        elif command -v python >/dev/null 2>&1; then
                            PYTHON_CMD=python
                        else
                            echo "WARNING: Python is not installed in Jenkins container. Skipping unit test."
                            exit 0
                        fi

                        \$PYTHON_CMD -m venv .jenkins-venv
                        . .jenkins-venv/bin/activate

                        python -m pip install --upgrade pip
                        pip install -r requirements.txt
                        pytest test_app.py -v --tb=short --junit-xml=test-results.xml
                    """
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'medicine-stock-devops/app/test-results.xml'
                }
            }
        }

        stage('3. Build Docker Image') {
            steps {
                script {
                    echo "========== Building Docker Image =========="
                    sh """
                        if ! command -v docker >/dev/null 2>&1; then
                            echo "WARNING: Docker CLI is not installed in Jenkins container. Skipping Docker build."
                            exit 0
                        fi

                        docker build \
                            -t ${DOCKER_IMAGE}:${EFFECTIVE_IMAGE_TAG} \
                            -t ${DOCKER_IMAGE}:latest \
                            -f ${PROJECT_DIR}/Dockerfile \
                            ${PROJECT_DIR}

                        docker image ls | grep medicine-stock || true
                    """
                }
            }
        }

        stage('4. Security Scan') {
            steps {
                script {
                    echo "========== Container Security Scan =========="
                    sh """
                        if command -v trivy >/dev/null 2>&1; then
                            trivy image --exit-code 0 --severity CRITICAL,HIGH ${DOCKER_IMAGE}:${EFFECTIVE_IMAGE_TAG}
                        else
                            echo "Trivy not installed, skipping security scan."
                        fi
                    """
                }
            }
        }

        stage('5. Push to Docker Registry') {
            when {
                expression { params.PUSH_TO_REGISTRY == true }
            }
            steps {
                script {
                    echo "========== Pushing Image to Docker Hub =========="
                    withCredentials([usernamePassword(
                        credentialsId: 'dockerhub-credentials',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh """
                            if ! command -v docker >/dev/null 2>&1; then
                                echo "WARNING: Docker CLI is not installed in Jenkins container. Skipping Docker push."
                                exit 0
                            fi

                            echo "\$DOCKER_PASS" | docker login -u "\$DOCKER_USER" --password-stdin
                            docker push ${DOCKER_IMAGE}:${EFFECTIVE_IMAGE_TAG}
                            docker push ${DOCKER_IMAGE}:latest
                            docker logout
                            echo "Image pushed successfully."
                        """
                    }
                }
            }
        }

        stage('6. Deploy to Kubernetes') {
            when {
                expression { params.DEPLOY_K8S == true }
            }
            steps {
                script {
                    echo "========== Phase 3: Terraform + Ansible =========="

                    sh """
                        if command -v terraform >/dev/null 2>&1; then
                            cd ${PROJECT_DIR}/terraform
                            terraform init
                            terraform validate
                            terraform plan -out=tfplan
                            terraform apply -auto-approve tfplan
                            cd ../../
                        else
                            echo "WARNING: Terraform is not installed in Jenkins container. Skipping Terraform."
                        fi
                    """

                    sh """
                        if command -v ansible-playbook >/dev/null 2>&1; then
                            cd ${PROJECT_DIR}/ansible
                            ansible --version
                            ansible-playbook -i inventory playbook.yml -v
                            cd ../../
                        else
                            echo "WARNING: Ansible is not installed in Jenkins container. Skipping Ansible."
                        fi
                    """

                    echo "========== Phase 4: Kubernetes Deployment =========="

                    sh """
                        if ! command -v kubectl >/dev/null 2>&1; then
                            echo "WARNING: kubectl is not installed in Jenkins container. Skipping Kubernetes deploy."
                            exit 0
                        fi

                        kubectl get ns ${KUBE_NAMESPACE} || kubectl create ns ${KUBE_NAMESPACE}

                        kubectl create serviceaccount medicine-stock-sa -n ${KUBE_NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -

                        kubectl create configmap medicine-stock-config \
                            --from-literal=DB_PATH=/app/medicine.db \
                            --from-literal=PYTHONUNBUFFERED=1 \
                            --from-literal=LOG_LEVEL=INFO \
                            --from-literal=ENVIRONMENT=development \
                            -n ${KUBE_NAMESPACE} \
                            --dry-run=client -o yaml | kubectl apply -f -

                        kubectl create secret generic medicine-stock-secrets \
                            --from-literal=SECRET_KEY=dev-secret-key \
                            --from-literal=DOCKER_REGISTRY_USERNAME=piyatida26 \
                            --from-literal=DOCKER_REGISTRY_PASSWORD=dummy \
                            -n ${KUBE_NAMESPACE} \
                            --dry-run=client -o yaml | kubectl apply -f -

                        kubectl apply -f ${PROJECT_DIR}/k8s/deployment.yaml
                        kubectl apply -f ${PROJECT_DIR}/k8s/service.yaml

                        kubectl set image deployment/medicine-stock \
                            medicine-stock=${DOCKER_IMAGE}:${EFFECTIVE_IMAGE_TAG} \
                            -n ${KUBE_NAMESPACE} || true

                        kubectl rollout status deployment/medicine-stock -n ${KUBE_NAMESPACE} --timeout=5m
                        kubectl get pods -n ${KUBE_NAMESPACE}
                        kubectl get svc -n ${KUBE_NAMESPACE}
                    """
                }
            }
        }
    }

    post {
        always {
            script {
                echo "========== Pipeline Finished =========="
                sh """
                    if command -v docker >/dev/null 2>&1; then
                        docker image prune -f --filter "until=24h" || true
                    else
                        echo "Docker CLI not found, skip docker cleanup."
                    fi
                """
            }
        }

        success {
            script {
                echo "========== Build Successful =========="
                sh """
                    echo "Build completed successfully at \$(date)" > build-status.txt
                    echo "Image: ${DOCKER_IMAGE}:${EFFECTIVE_IMAGE_TAG}" >> build-status.txt
                """
            }
        }

        failure {
            script {
                echo "========== Build Failed =========="
            }
        }

        unstable {
            script {
                echo "========== Build Unstable =========="
            }
        }
    }
}